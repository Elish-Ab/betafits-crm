import React, { useState } from 'react';
import { MOCK_PARTNERS } from '../services/mockData';
import { PartnerType, PartnerStage, Partner } from '../types';
import { Handshake, Mail, Zap, CheckCircle, Clock, X, Globe, Linkedin, MapPin, Briefcase, Users } from 'lucide-react';
import { generateOutreachEmail } from '../services/geminiService';

const Partners: React.FC = () => {
  const [selectedType, setSelectedType] = useState<PartnerType | 'All'>('All');
  const [selectedPartner, setSelectedPartner] = useState<Partner | null>(null);
  const [generatedEmail, setGeneratedEmail] = useState<string | null>(null);
  const [loadingId, setLoadingId] = useState<string | null>(null);

  const filteredPartners = MOCK_PARTNERS.filter(p => 
    selectedType === 'All' || p.type === selectedType
  );

  const handleDraftEmail = async (partner: any) => {
    setLoadingId(partner.id);
    setGeneratedEmail(null);
    
    const email = await generateOutreachEmail(
      partner.contactName || "Partner",
      partner.name,
      "We have new high-growth startups in your portfolio that are currently using PEOs like TriNet and could benefit from migration.",
      "Matt Prisco"
    );
    
    setGeneratedEmail(email);
    setLoadingId(null);
    alert(`Draft generated for ${partner.name}. \n\n${email}`);
  };

  return (
    <div className="space-y-6 h-[calc(100vh-8rem)] relative">
      <div className="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <div>
            <h2 className="text-2xl font-bold text-gray-800">Partner Directory</h2>
            <p className="text-sm text-gray-500 mt-1">Manage relationships with VCs, Fractional CFOs, and HR firms.</p>
        </div>
        <div className="flex space-x-2 bg-white p-1 rounded-lg shadow-sm border border-gray-200">
          {['All', PartnerType.VC_PE, PartnerType.FractionalCFO, PartnerType.FractionalHR].map((type) => (
            <button
              key={type}
              onClick={() => setSelectedType(type as any)}
              className={`px-3 py-1.5 text-sm font-medium rounded-md transition-colors ${
                selectedType === type 
                  ? 'bg-[#84bd5e] text-white shadow-sm' 
                  : 'text-gray-600 hover:bg-gray-50'
              }`}
            >
              {type === 'All' ? 'All' : type}
            </button>
          ))}
        </div>
      </div>

      <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 overflow-y-auto pb-4">
        {filteredPartners.map((partner) => (
          <div key={partner.id} className="bg-white rounded-xl shadow-sm border border-gray-100 p-6 flex flex-col relative overflow-hidden hover:shadow-md transition-shadow">
            {partner.activePartnership && (
                <div className="absolute top-0 right-0 w-16 h-16 pointer-events-none">
                    <div className="absolute transform rotate-45 bg-[#84bd5e] text-white text-[10px] font-bold py-1 right-[-35px] top-[32px] w-[170px] text-center shadow-sm">
                        ACTIVE
                    </div>
                </div>
            )}
            
            <div className="flex items-start justify-between mb-4 cursor-pointer" onClick={() => setSelectedPartner(partner)}>
              <div className="flex items-center">
                <div className="p-2.5 bg-gray-50 rounded-lg mr-3 border border-gray-100">
                  <Handshake className="w-6 h-6 text-gray-600" />
                </div>
                <div>
                  <h3 className="text-lg font-bold text-gray-900 hover:text-[#84bd5e] transition-colors">{partner.name}</h3>
                  <span className="text-xs text-gray-500 bg-gray-100 px-2 py-0.5 rounded border border-gray-200">{partner.type}</span>
                </div>
              </div>
            </div>

            <div className="flex-1 space-y-3 mb-6 cursor-pointer" onClick={() => setSelectedPartner(partner)}>
              <div className="text-sm text-gray-600 flex justify-between">
                <span className="font-medium text-gray-900">Contact:</span> 
                <span>{partner.contactName || 'N/A'}</span>
              </div>
              <div className="text-sm text-gray-600 flex justify-between">
                <span className="font-medium text-gray-900">Referrals:</span> 
                <span className="font-semibold text-[#84bd5e]">{partner.referralsMade}</span>
              </div>
              <div className="text-sm text-gray-600 flex justify-between items-center">
                <span className="font-medium text-gray-900">Stage:</span> 
                <span className={`inline-flex items-center px-2 py-0.5 rounded text-xs font-medium border ${
                    partner.stage === PartnerStage.Active 
                    ? 'bg-green-50 text-green-700 border-green-100' 
                    : 'bg-yellow-50 text-yellow-700 border-yellow-100'
                }`}>
                    {partner.stage === PartnerStage.Active ? <CheckCircle className="w-3 h-3 mr-1"/> : <Clock className="w-3 h-3 mr-1"/>}
                    {partner.stage}
                </span>
              </div>
            </div>

            <div className="mt-auto pt-4 border-t border-gray-100 flex space-x-3">
               <button 
                 className="flex-1 flex items-center justify-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 transition-colors"
                 onClick={() => handleDraftEmail(partner)}
                 disabled={loadingId === partner.id}
               >
                 {loadingId === partner.id ? (
                    <Zap className="w-4 h-4 mr-2 animate-pulse text-yellow-500" />
                 ) : (
                    <Mail className="w-4 h-4 mr-2" />
                 )}
                 {loadingId === partner.id ? 'AI...' : 'Outreach'}
               </button>
               <button 
                 onClick={() => setSelectedPartner(partner)}
                 className="flex-1 px-4 py-2 bg-[#84bd5e] text-white text-sm font-medium rounded-lg hover:bg-[#76aa52] transition-colors shadow-sm"
               >
                 Details
               </button>
            </div>
          </div>
        ))}
      </div>

      {/* Partner Detail Slide-over */}
      {selectedPartner && (
        <div className="absolute inset-y-0 right-0 w-1/3 bg-white shadow-2xl border-l border-gray-200 z-50 flex flex-col transform transition-transform duration-300 ease-in-out">
             <div className="flex items-center justify-between p-6 border-b border-gray-100">
                <div className="flex items-center space-x-3">
                    <div className="h-12 w-12 bg-gray-50 rounded-full flex items-center justify-center text-gray-600">
                        <Handshake className="w-6 h-6" />
                    </div>
                    <div>
                        <h3 className="text-xl font-bold text-gray-900">{selectedPartner.name}</h3>
                        <span className="text-sm text-gray-500 bg-gray-100 px-2 py-0.5 rounded">{selectedPartner.type}</span>
                    </div>
                </div>
                <button 
                    onClick={() => setSelectedPartner(null)}
                    className="p-2 hover:bg-gray-100 rounded-full transition-colors text-gray-400 hover:text-gray-600"
                >
                    <X className="w-5 h-5" />
                </button>
            </div>

            <div className="flex-1 overflow-y-auto p-6 space-y-8">
                {/* Market Intel Section */}
                <div>
                    <h4 className="text-lg font-bold text-gray-800 mb-4 flex items-center">
                        <Briefcase className="w-5 h-5 mr-2 text-[#84bd5e]" /> Firm Intelligence
                    </h4>
                    <p className="text-sm text-gray-600 leading-relaxed mb-6">
                        {selectedPartner.description || 'No description available.'}
                    </p>
                    
                    <div className="bg-white border border-gray-200 rounded-xl p-5 shadow-sm grid grid-cols-2 gap-6">
                        <div>
                            <p className="text-xs text-gray-400 uppercase font-bold">Founded</p>
                            <p className="text-lg font-medium text-gray-900 mt-1">{selectedPartner.foundedYear || 'N/A'}</p>
                        </div>
                        <div>
                            <p className="text-xs text-gray-400 uppercase font-bold">Location</p>
                            <div className="flex items-center mt-1">
                                <MapPin className="w-4 h-4 mr-1 text-gray-400" />
                                <span className="text-lg font-medium text-gray-900">{selectedPartner.location || 'N/A'}</span>
                            </div>
                        </div>
                        <div className="col-span-2 flex space-x-4">
                            {selectedPartner.website && (
                                <a href={`https://${selectedPartner.website}`} target="_blank" rel="noreferrer" className="text-sm text-blue-600 hover:underline flex items-center">
                                    <Globe className="w-4 h-4 mr-1" /> Website
                                </a>
                            )}
                            {selectedPartner.linkedin && (
                                <a href={`https://${selectedPartner.linkedin}`} target="_blank" rel="noreferrer" className="text-sm text-blue-700 hover:underline flex items-center">
                                    <Linkedin className="w-4 h-4 mr-1" /> LinkedIn
                                </a>
                            )}
                        </div>
                    </div>
                </div>

                {/* Investment/Focus Profile */}
                {(selectedPartner.type === PartnerType.VC_PE || selectedPartner.investmentFocus) && (
                    <div>
                        <h4 className="text-lg font-bold text-gray-800 mb-4 flex items-center">
                            <Zap className="w-5 h-5 mr-2 text-[#84bd5e]" /> {selectedPartner.type === PartnerType.VC_PE ? 'Investment Profile' : 'Business Focus'}
                        </h4>
                        <div className="bg-gray-50 p-4 rounded-xl border border-gray-100">
                            <p className="text-xs text-gray-400 uppercase font-bold mb-2">Focus Areas</p>
                            <div className="flex flex-wrap gap-2">
                                {selectedPartner.investmentFocus ? (
                                    selectedPartner.investmentFocus.split(',').map((tag, idx) => (
                                        <span key={idx} className="bg-white text-gray-700 px-3 py-1 rounded-full text-sm font-medium border border-gray-200 shadow-sm">
                                            {tag.trim()}
                                        </span>
                                    ))
                                ) : (
                                    <span className="text-sm text-gray-500 italic">No specific focus data available.</span>
                                )}
                            </div>
                        </div>
                    </div>
                )}

                {/* Relationships */}
                <div>
                    <h4 className="text-lg font-bold text-gray-800 mb-4 flex items-center">
                        <Users className="w-5 h-5 mr-2 text-[#84bd5e]" /> Key People
                    </h4>
                    <div className="flex items-center bg-white p-3 rounded-lg border border-gray-200 shadow-sm">
                        <div className="h-10 w-10 bg-indigo-50 rounded-full flex items-center justify-center text-indigo-600 font-bold mr-3">
                            {selectedPartner.contactName ? selectedPartner.contactName.charAt(0) : '?'}
                        </div>
                        <div>
                            <p className="font-medium text-gray-900">{selectedPartner.contactName || 'Unknown Contact'}</p>
                            <p className="text-xs text-gray-500">Primary Point of Contact</p>
                        </div>
                    </div>
                </div>

            </div>
        </div>
      )}
    </div>
  );
};

export default Partners;
