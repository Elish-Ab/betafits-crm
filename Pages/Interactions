import React from 'react';
import { MOCK_INTERACTIONS } from '../services/mockData';
import { Phone, Mail, Users, Linkedin } from 'lucide-react';

const getIcon = (type: string) => {
    switch (type) {
        case 'Call': return Phone;
        case 'Email': return Mail;
        case 'Meeting': return Users;
        case 'LinkedIn': return Linkedin;
        default: return Users;
    }
}

const Interactions: React.FC = () => {
  return (
    <div className="max-w-4xl mx-auto">
      <h2 className="text-2xl font-bold text-gray-800 mb-6">Recent Activity</h2>
      <div className="space-y-8">
        {MOCK_INTERACTIONS.map((interaction, idx) => {
            const Icon = getIcon(interaction.type);
            return (
                <div key={interaction.id} className="relative flex gap-6 pb-6 group">
                    {/* Timeline Line */}
                    {idx !== MOCK_INTERACTIONS.length - 1 && (
                        <div className="absolute left-[19px] top-10 bottom-0 w-0.5 bg-gray-200 group-hover:bg-indigo-200 transition-colors"></div>
                    )}
                    
                    <div className="relative flex-shrink-0 h-10 w-10 bg-white border-2 border-gray-200 rounded-full flex items-center justify-center z-10">
                        <Icon className="w-5 h-5 text-gray-500" />
                    </div>

                    <div className="flex-1 bg-white p-4 rounded-lg border border-gray-100 shadow-sm">
                        <div className="flex justify-between items-start mb-2">
                            <div>
                                <span className="font-semibold text-gray-900">{interaction.user}</span>
                                <span className="text-gray-500 text-sm mx-2">logged a</span>
                                <span className="font-medium text-indigo-600">{interaction.type}</span>
                            </div>
                            <span className="text-xs text-gray-400 whitespace-nowrap">{interaction.date}</span>
                        </div>
                        <p className="text-gray-600 text-sm leading-relaxed">
                            {interaction.summary}
                        </p>
                    </div>
                </div>
            )
        })}
      </div>
    </div>
  );
};

export default Interactions;
