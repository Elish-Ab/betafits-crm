
import React, { useState } from 'react';
import { Link, useLocation } from 'react-router-dom';
import { 
  LayoutDashboard, 
  Building2, 
  Target, 
  Users, 
  Settings, 
  Search, 
  Menu,
  Globe,
  PieChart
} from 'lucide-react';

interface LayoutProps {
  children: React.ReactNode;
}

interface SidebarItemProps {
  to: string;
  icon: React.FC<any>;
  label: string;
  active: boolean;
}

const SidebarItem: React.FC<SidebarItemProps> = ({ to, icon: Icon, label, active }) => (
  <Link
    to={to}
    className={`flex items-center px-6 py-3 text-sm font-medium transition-colors duration-200 ${
      active 
        ? 'text-[#84bd5e] bg-green-50 border-r-4 border-[#84bd5e]' 
        : 'text-gray-500 hover:text-gray-900 hover:bg-gray-50'
    }`}
  >
    <Icon className={`w-5 h-5 mr-3 ${active ? 'text-[#84bd5e]' : 'text-gray-400'}`} />
    {label}
  </Link>
);

const Layout: React.FC<LayoutProps> = ({ children }) => {
  const location = useLocation();
  const [isMobileMenuOpen, setIsMobileMenuOpen] = useState(false);

  const navItems = [
    { to: '/', icon: LayoutDashboard, label: 'Dashboard' },
    { to: '/universe', icon: Globe, label: 'Universe' },
    { to: '/companies', icon: Building2, label: 'Prospects' },
    { to: '/prospects', icon: Target, label: 'Opportunities' },
    { to: '/partners', icon: Users, label: 'Partners' },
    { to: '/analytics', icon: PieChart, label: 'Analytics' },
  ];

  return (
    <div className="flex h-screen bg-gray-50 overflow-hidden">
      {/* Mobile Menu Overlay */}
      {isMobileMenuOpen && (
        <div 
          className="fixed inset-0 z-20 bg-black bg-opacity-50 lg:hidden" 
          onClick={() => setIsMobileMenuOpen(false)}
        />
      )}

      {/* Sidebar - Always visible on desktop */}
      <aside className={`
        fixed inset-y-0 left-0 z-30 w-64 bg-white shadow-lg transform transition-transform duration-300 ease-in-out lg:translate-x-0 lg:static lg:inset-0 flex flex-col
        ${isMobileMenuOpen ? 'translate-x-0' : '-translate-x-full'}
      `}>
        <div className="flex items-center justify-center h-16 bg-white border-b border-gray-100">
          <div className="flex items-center space-x-2">
             {/* Logo Placeholder - Betafits Clover Concept */}
             <div className="w-8 h-8 rounded-full bg-[#84bd5e] flex items-center justify-center text-white font-bold text-lg">
                β
             </div>
             <h1 className="text-gray-600 text-xl font-bold tracking-wide">Betafits</h1>
          </div>
        </div>
        
        <div className="flex flex-col justify-between flex-1 overflow-y-auto">
            <nav className="mt-6 space-y-1">
            {navItems.map((item) => (
                <SidebarItem 
                key={item.to}
                to={item.to}
                icon={item.icon}
                label={item.label}
                active={location.pathname === item.to}
                />
            ))}
            </nav>
            <div className="p-4 border-t border-gray-100">
                <SidebarItem to="/settings" icon={Settings} label="Settings" active={location.pathname === '/settings'} />
            </div>
        </div>
      </aside>

      {/* Main Content */}
      <div className="flex-1 flex flex-col overflow-hidden">
        {/* Header */}
        <header className="flex items-center justify-between h-16 px-6 bg-white border-b border-gray-100 shadow-sm z-10">
          <button 
            className="p-1 text-gray-500 lg:hidden focus:outline-none"
            onClick={() => setIsMobileMenuOpen(true)}
          >
            <Menu className="w-6 h-6" />
          </button>

          <div className="flex-1 max-w-xl ml-4 lg:ml-0">
            <div className="relative">
              <span className="absolute inset-y-0 left-0 flex items-center pl-3">
                <Search className="w-4 h-4 text-gray-400" />
              </span>
              <input
                type="text"
                className="w-full py-2 pl-10 pr-4 text-sm text-gray-700 bg-gray-50 border border-transparent rounded-lg focus:outline-none focus:bg-white focus:border-[#84bd5e] focus:ring-0 transition-colors"
                placeholder="Search..."
              />
            </div>
          </div>

          <div className="flex items-center space-x-4">
            <div className="relative">
              <button className="flex items-center space-x-2 focus:outline-none hover:bg-gray-50 p-1.5 rounded-lg transition-colors">
                <div className="w-8 h-8 bg-[#84bd5e] bg-opacity-10 rounded-full flex items-center justify-center text-[#84bd5e] font-bold text-xs">
                    MP
                </div>
                <span className="hidden text-sm font-medium text-gray-600 lg:block">Matt Prisco</span>
              </button>
            </div>
          </div>
        </header>

        {/* Content Body */}
        <main className="flex-1 overflow-x-hidden overflow-y-auto bg-gray-50 p-6">
          {children}
        </main>
      </div>
    </div>
  );
};

export default Layout;
