
import React, { useState } from 'react';
import { MOCK_PROSPECTS, MOCK_PARTNER_OPPORTUNITIES, MOCK_INTERACTIONS } from '../services/mockData';
import { SalesStage, PartnerStage, PartnerType, Interaction } from '../types';
import { DollarSign, Handshake, X, Phone, Mail, Users, Linkedin, Calendar, Clock, Plus, ArrowRight } from 'lucide-react';

const SALES_STAGES = [
  SalesStage.Contact,
  SalesStage.Meeting,
  SalesStage.Opportunity,
  SalesStage.Consulting,
  SalesStage.FinishLine,
  SalesStage.Customer
];

const PARTNER_STAGES = [
  PartnerStage.Identified,
  PartnerStage.Outreach,
  PartnerStage.Meeting,
  PartnerStage.DueDiligence,
  PartnerStage.Agreement,
  PartnerStage.Active
];

const getIcon = (type: string) => {
    switch (type) {
        case 'Call': return Phone;
        case 'Email': return Mail;
        case 'Meeting': return Users;
        case 'LinkedIn': return Linkedin;
        default: return Users;
    }
}

const Prospects: React.FC = () => {
  const [activeTab, setActiveTab] = useState<'sales' | 'partners'>('sales');
  const [selectedOpportunity, setSelectedOpportunity] = useState<any | null>(null);

  const opportunityInteractions = selectedOpportunity 
    ? MOCK_INTERACTIONS.filter(i => {
        if (activeTab === 'sales') {
            return i.prospectId === selectedOpportunity.id || i.companyId === selectedOpportunity.companyId;
        } else {
            return i.partnerId === selectedOpportunity.partnerId;
        }
    }).sort((a,b) => new Date(b.date).getTime() - new Date(a.date).getTime())
    : [];

  return (
    <div className="h-[calc(100vh-8rem)] flex flex-col relative">
      <div className="flex justify-between items-center mb-6">
        <div className="flex items-center space-x-4">
            <h2 className="text-2xl font-bold text-gray-800">Opportunities</h2>
            <div className="bg-white rounded-lg p-1 shadow-sm border border-gray-200 flex">
                <button
                    onClick={() => { setActiveTab('sales'); setSelectedOpportunity(null); }}
                    className={`px-4 py-2 text-sm font-medium rounded-md flex items-center transition-all ${
                        activeTab === 'sales' 
                        ? 'bg-[#84bd5e] text-white shadow-sm' 
                        : 'text-gray-500 hover:bg-gray-50'
                    }`}
                >
                    <DollarSign className="w-4 h-4 mr-2" />
                    Sales
                </button>
                <button
                    onClick={() => { setActiveTab('partners'); setSelectedOpportunity(null); }}
                    className={`px-4 py-2 text-sm font-medium rounded-md flex items-center transition-all ${
                        activeTab === 'partners' 
                        ? 'bg-gray-800 text-white shadow-sm' 
                        : 'text-gray-500 hover:bg-gray-50'
                    }`}
                >
                    <Handshake className="w-4 h-4 mr-2" />
                    Partnerships
                </button>
            </div>
        </div>
        <button className={`text-white px-4 py-2 rounded-lg transition-colors shadow-sm flex items-center ${
            activeTab === 'sales' ? 'bg-[#84bd5e] hover:bg-[#76aa52]' : 'bg-gray-800 hover:bg-gray-900'
        }`}>
          <Plus className="w-4 h-4 mr-2" />
          New {activeTab === 'sales' ? 'Sales' : 'Partner'} Opportunity
        </button>
      </div>

      <div className="flex-1 overflow-x-auto overflow-y-hidden pb-4">
        {activeTab === 'sales' ? (
            /* SALES PIPELINE */
            <div className="flex h-full space-x-4 min-w-[1200px]">
            {SALES_STAGES.map((stage) => {
                const prospects = MOCK_PROSPECTS.filter(p => p.stage === stage);
                // Calculate Weighted Value: Deal Value * (Probability / 100)
                const totalWeightedValue = prospects.reduce((sum, p) => sum + (p.value * (p.probability / 100)), 0);

                return (
                <div key={stage} className="flex-1 flex flex-col bg-gray-100 rounded-xl min-w-[280px] border border-gray-200">
                    <div className="p-3 bg-white rounded-t-xl border-b border-gray-200 sticky top-0">
                        <div className="flex justify-between items-center mb-1">
                            <h3 className="font-bold text-gray-700 text-sm uppercase tracking-wide">{stage}</h3>
                            <span className="text-xs text-gray-500 bg-gray-100 px-2 py-0.5 rounded-full font-medium border border-gray-200">{prospects.length}</span>
                        </div>
                        <div className="text-xs font-semibold text-[#84bd5e]">
                            ${totalWeightedValue.toLocaleString()} <span className="text-gray-400 font-normal">(Weighted)</span>
                        </div>
                    </div>
                    
                    <div className="p-2 flex-1 overflow-y-auto hide-scrollbar space-y-3 bg-gray-50">
                    {prospects.map((prospect) => (
                        <div 
                            key={prospect.id} 
                            onClick={() => setSelectedOpportunity(prospect)}
                            className="bg-white p-4 rounded-lg shadow-sm border border-gray-200 hover:shadow-md transition-shadow cursor-pointer border-l-4 border-l-[#84bd5e] relative group"
                        >
                        <div className="flex justify-between items-start mb-2">
                            <h4 className="font-semibold text-gray-900">{prospect.companyName}</h4>
                            <div className={`text-[10px] font-bold px-1.5 py-0.5 rounded ${
                                prospect.icpScore >= 80 ? 'bg-green-50 text-green-700' :
                                prospect.icpScore >= 50 ? 'bg-yellow-50 text-yellow-700' :
                                'bg-red-50 text-red-700'
                            }`}>
                                {prospect.icpScore}
                            </div>
                        </div>
                        
                        <div className="flex justify-between items-center text-xs text-gray-500 mb-3">
                            <span className="bg-green-50 text-green-700 px-1.5 py-0.5 rounded font-medium border border-green-100">${prospect.value.toLocaleString()}</span>
                            <span className="font-medium">{prospect.probability}% Prob.</span>
                        </div>
                        <div className="flex justify-between items-center pt-3 border-t border-gray-100">
                            <div className="flex items-center">
                                <div className="w-6 h-6 rounded-full bg-green-50 text-[#84bd5e] flex items-center justify-center text-[10px] font-bold border border-green-100">
                                    {prospect.owner.charAt(0)}
                                </div>
                                <span className="ml-2 text-xs text-gray-500">{prospect.source}</span>
                            </div>
                        </div>
                        </div>
                    ))}
                    </div>
                </div>
                );
            })}
            </div>
        ) : (
            /* PARTNER PIPELINE */
            <div className="flex h-full space-x-4 min-w-[1200px]">
            {PARTNER_STAGES.map((stage) => {
                const opps = MOCK_PARTNER_OPPORTUNITIES.filter(p => p.stage === stage);

                return (
                <div key={stage} className="flex-1 flex flex-col bg-gray-100 rounded-xl min-w-[280px] border border-gray-200">
                    <div className="p-3 bg-white rounded-t-xl border-b border-gray-200 sticky top-0">
                        <div className="flex justify-between items-center mb-1">
                            <h3 className="font-bold text-gray-700 text-sm uppercase tracking-wide">{stage}</h3>
                            <span className="text-xs text-gray-500 bg-gray-100 px-2 py-0.5 rounded-full font-medium border border-gray-200">{opps.length}</span>
                        </div>
                    </div>
                    
                    <div className="p-2 flex-1 overflow-y-auto hide-scrollbar space-y-3 bg-gray-50">
                    {opps.map((opp) => (
                        <div 
                            key={opp.id} 
                            onClick={() => setSelectedOpportunity(opp)}
                            className="bg-white p-4 rounded-lg shadow-sm border border-gray-200 hover:shadow-md transition-shadow cursor-pointer border-l-4 border-l-gray-600"
                        >
                        <div className="flex justify-between items-start mb-2">
                            <h4 className="font-semibold text-gray-900">{opp.partnerName}</h4>
                        </div>
                        <span className="inline-block px-2 py-0.5 rounded text-[10px] font-semibold bg-gray-100 text-gray-600 mb-3 border border-gray-200">
                            {opp.type}
                        </span>
                        
                        <div className="flex justify-between items-center pt-3 border-t border-gray-100">
                            <div className="flex items-center">
                                <div className="w-6 h-6 rounded-full bg-gray-100 text-gray-600 flex items-center justify-center text-[10px] font-bold">
                                    {opp.owner.charAt(0)}
                                </div>
                                <span className="ml-2 text-xs text-gray-500 font-medium">{opp.probability}% Prob.</span>
                            </div>
                        </div>
                        </div>
                    ))}
                    </div>
                </div>
                );
            })}
            </div>
        )}
      </div>

      {/* Detail Slide-over */}
      {selectedOpportunity && (
        <div className="absolute inset-y-0 right-0 w-1/3 bg-white shadow-2xl border-l border-gray-200 z-50 flex flex-col transform transition-transform duration-300 ease-in-out">
            <div className="flex items-center justify-between p-6 border-b border-gray-100">
                <div>
                    <h3 className="text-xl font-bold text-gray-900">
                        {activeTab === 'sales' ? selectedOpportunity.companyName : selectedOpportunity.partnerName}
                    </h3>
                    <div className="flex items-center mt-1 space-x-2">
                        <span className={`px-2 py-0.5 rounded text-xs font-medium ${activeTab === 'sales' ? 'bg-green-50 text-green-700' : 'bg-gray-100 text-gray-600'}`}>
                             {activeTab === 'sales' ? 'Sales Opportunity' : 'Partner Opportunity'}
                        </span>
                        <span className="text-gray-300">•</span>
                        <span className="text-sm text-gray-500">{selectedOpportunity.stage}</span>
                    </div>
                </div>
                <button 
                    onClick={() => setSelectedOpportunity(null)}
                    className="p-2 hover:bg-gray-100 rounded-full transition-colors text-gray-400 hover:text-gray-600"
                >
                    <X className="w-5 h-5" />
                </button>
            </div>

            <div className="flex-1 overflow-y-auto p-6">
                {/* Key Stats */}
                <div className="grid grid-cols-2 gap-4 mb-8">
                    <div className="bg-gray-50 p-4 rounded-lg border border-gray-100">
                        <p className="text-xs text-gray-500 uppercase tracking-wide font-bold">Owner</p>
                        <p className="font-medium text-gray-900 mt-1">{selectedOpportunity.owner}</p>
                    </div>
                    <div className="bg-gray-50 p-4 rounded-lg border border-gray-100">
                        <p className="text-xs text-gray-500 uppercase tracking-wide font-bold">Probability</p>
                        <p className="font-medium text-gray-900 mt-1">{selectedOpportunity.probability}%</p>
                    </div>
                    {activeTab === 'sales' && (
                        <>
                            <div className="bg-gray-50 p-4 rounded-lg border border-gray-100">
                                <p className="text-xs text-gray-500 uppercase tracking-wide font-bold">Deal Value</p>
                                <p className="font-medium text-[#84bd5e] mt-1">${selectedOpportunity.value.toLocaleString()}</p>
                            </div>
                            <div className="bg-gray-50 p-4 rounded-lg border border-gray-100">
                                <p className="text-xs text-gray-500 uppercase tracking-wide font-bold">Weighted Value</p>
                                <p className="font-medium text-gray-900 mt-1">${(selectedOpportunity.value * (selectedOpportunity.probability / 100)).toLocaleString()}</p>
                            </div>
                            <div className="bg-gray-50 p-4 rounded-lg border border-gray-100">
                                <p className="text-xs text-gray-500 uppercase tracking-wide font-bold">ICP Score</p>
                                <p className="font-medium text-gray-900 mt-1">{selectedOpportunity.icpScore}</p>
                            </div>
                        </>
                    )}
                    {activeTab === 'partners' && (
                        <div className="bg-gray-50 p-4 rounded-lg col-span-2 border border-gray-100">
                            <p className="text-xs text-gray-500 uppercase tracking-wide font-bold">Type</p>
                            <p className="font-medium text-gray-900 mt-1">{selectedOpportunity.type}</p>
                        </div>
                    )}
                </div>

                {/* Activity Timeline */}
                <div className="mb-6 flex justify-between items-center">
                    <h4 className="text-lg font-bold text-gray-800">Activity</h4>
                    <button className="text-xs font-medium text-[#84bd5e] hover:text-[#76aa52] flex items-center bg-green-50 px-3 py-1.5 rounded-full border border-green-100 transition-colors">
                        <Plus className="w-3 h-3 mr-1"/> Log Activity
                    </button>
                </div>

                <div className="space-y-6 relative pl-2">
                    {/* Vertical Line */}
                    <div className="absolute left-5 top-2 bottom-4 w-px bg-gray-200"></div>

                    {opportunityInteractions.length > 0 ? (
                        opportunityInteractions.map((interaction) => {
                            const Icon = getIcon(interaction.type);
                            return (
                                <div key={interaction.id} className="relative flex gap-4 group">
                                    <div className="relative flex-shrink-0 h-8 w-8 bg-white border border-gray-200 rounded-full flex items-center justify-center z-10 shadow-sm">
                                        <Icon className="w-4 h-4 text-gray-500" />
                                    </div>
                                    <div className="flex-1 bg-white p-3 rounded-lg border border-gray-200 shadow-sm group-hover:border-[#84bd5e] group-hover:border-opacity-30 transition-colors">
                                        <div className="flex justify-between items-start mb-1">
                                            <span className="font-semibold text-sm text-gray-900">{interaction.type}</span>
                                            <span className="text-xs text-gray-400">{interaction.date}</span>
                                        </div>
                                        <p className="text-xs text-gray-600 leading-relaxed">{interaction.summary}</p>
                                        <div className="mt-2 flex items-center text-[10px] text-gray-400">
                                            <span className="font-medium text-gray-500">{interaction.user}</span>
                                        </div>
                                    </div>
                                </div>
                            );
                        })
                    ) : (
                        <div className="text-center py-8">
                            <div className="bg-gray-50 rounded-full h-12 w-12 flex items-center justify-center mx-auto mb-3 border border-gray-100">
                                <Calendar className="w-6 h-6 text-gray-300" />
                            </div>
                            <p className="text-sm text-gray-500">No interactions logged yet.</p>
                        </div>
                    )}
                </div>
            </div>
        </div>
      )}
    </div>
  );
};

export default Prospects;
