
import React, { useState, useMemo } from 'react';
import { MOCK_PEO_STATS, MOCK_DOC_PROVIDERS, MOCK_316_ADMINS } from '../services/mockData';
import { TrendingUp, TrendingDown, Minus, Building2, FileText, ShieldCheck, Filter, ArrowUpDown, Search } from 'lucide-react';

const Analytics: React.FC = () => {
  const [activeTab, setActiveTab] = useState<'peos' | 'providers' | 'admins'>('peos');
  
  // Filtering & Sorting State
  const [searchQuery, setSearchQuery] = useState('');
  const [minClientFilter, setMinClientFilter] = useState<number | ''>('');
  const [minWCPoliciesFilter, setMinWCPoliciesFilter] = useState<number | ''>(''); // New PEO specific filter
  const [trendFilter, setTrendFilter] = useState<string>('all');
  const [minMarketShareFilter, setMinMarketShareFilter] = useState<number | ''>('');
  
  const [sortConfig, setSortConfig] = useState<{ key: string; direction: 'asc' | 'desc' } | null>({ key: 'clientCount', direction: 'desc' });

  const getTrendIcon = (trend?: 'up' | 'down' | 'flat') => {
    if (trend === 'up') return <div className="flex items-center text-green-600 bg-green-50 px-2 py-1 rounded-full text-xs font-medium w-fit"><TrendingUp className="w-3 h-3 mr-1" /> Growing</div>;
    if (trend === 'down') return <div className="flex items-center text-red-500 bg-red-50 px-2 py-1 rounded-full text-xs font-medium w-fit"><TrendingDown className="w-3 h-3 mr-1" /> Declining</div>;
    return <div className="flex items-center text-gray-500 bg-gray-100 px-2 py-1 rounded-full text-xs font-medium w-fit"><Minus className="w-3 h-3 mr-1" /> Flat</div>;
  };

  // Data Processing
  const processedData = useMemo(() => {
    let data: any[] = [];
    if (activeTab === 'peos') data = [...MOCK_PEO_STATS];
    else if (activeTab === 'providers') data = [...MOCK_DOC_PROVIDERS];
    else data = [...MOCK_316_ADMINS];

    // 1. Search Filter (Name or EIN)
    if (searchQuery) {
        const lowerQuery = searchQuery.toLowerCase();
        data = data.filter(item => 
            item.name.toLowerCase().includes(lowerQuery) || 
            (item.ein && item.ein.includes(lowerQuery)) ||
            (item.providerName && item.providerName.toLowerCase().includes(lowerQuery))
        );
    }

    // 2. Min Client Filter
    if (minClientFilter !== '') {
        data = data.filter(item => item.clientCount >= Number(minClientFilter));
    }

    // 3. WC Policies Filter (PEO Specific)
    if (activeTab === 'peos' && minWCPoliciesFilter !== '') {
        data = data.filter(item => (item.wcPolicyCount || 0) >= Number(minWCPoliciesFilter));
    }

    // 4. Trend Filter (PEO Specific)
    if (activeTab === 'peos' && trendFilter !== 'all') {
        data = data.filter(item => item.trend === trendFilter);
    }

    // 5. Market Share Filter (Provider Specific)
    if (activeTab === 'providers' && minMarketShareFilter !== '') {
        data = data.filter(item => (item.marketShare || 0) >= Number(minMarketShareFilter));
    }

    // 6. Sorting
    if (sortConfig) {
        data.sort((a, b) => {
            const aValue = a[sortConfig.key];
            const bValue = b[sortConfig.key];

            if (aValue < bValue) {
                return sortConfig.direction === 'asc' ? -1 : 1;
            }
            if (aValue > bValue) {
                return sortConfig.direction === 'asc' ? 1 : -1;
            }
            return 0;
        });
    }

    return data;
  }, [activeTab, searchQuery, minClientFilter, minWCPoliciesFilter, trendFilter, minMarketShareFilter, sortConfig]);

  const handleSort = (key: string) => {
    let direction: 'asc' | 'desc' = 'desc';
    if (sortConfig && sortConfig.key === key && sortConfig.direction === 'desc') {
      direction = 'asc';
    }
    setSortConfig({ key, direction });
  };

  const SortIcon = ({ columnKey }: { columnKey: string }) => {
      if (sortConfig?.key !== columnKey) return <ArrowUpDown className="w-3 h-3 ml-1 text-gray-300" />;
      return sortConfig.direction === 'asc' 
        ? <ArrowUpDown className="w-3 h-3 ml-1 text-[#84bd5e] transform rotate-180" /> 
        : <ArrowUpDown className="w-3 h-3 ml-1 text-[#84bd5e]" />;
  };

  return (
    <div className="space-y-6 h-[calc(100vh-8rem)] flex flex-col">
      <div className="flex flex-col sm:flex-row justify-between items-start sm:items-end gap-4">
        <div>
          <h2 className="text-2xl font-bold text-gray-800">Analytics</h2>
          <p className="text-sm text-gray-500 mt-1">Market intelligence and rankings based on Form 5500 data.</p>
        </div>
        
        <div className="bg-white p-1 rounded-lg border border-gray-200 shadow-sm flex">
          <button
            onClick={() => { setActiveTab('peos'); setSortConfig({ key: 'clientCount', direction: 'desc' }); setSearchQuery(''); setMinClientFilter(''); }}
            className={`px-4 py-2 text-sm font-medium rounded-md flex items-center transition-colors ${
              activeTab === 'peos' ? 'bg-[#84bd5e] text-white shadow-sm' : 'text-gray-500 hover:bg-gray-50'
            }`}
          >
            <Building2 className="w-4 h-4 mr-2" />
            PEOs
          </button>
          <button
            onClick={() => { setActiveTab('providers'); setSortConfig({ key: 'clientCount', direction: 'desc' }); setSearchQuery(''); setMinClientFilter(''); }}
            className={`px-4 py-2 text-sm font-medium rounded-md flex items-center transition-colors ${
              activeTab === 'providers' ? 'bg-[#84bd5e] text-white shadow-sm' : 'text-gray-500 hover:bg-gray-50'
            }`}
          >
            <FileText className="w-4 h-4 mr-2" />
            401(k) Docs
          </button>
          <button
            onClick={() => { setActiveTab('admins'); setSortConfig({ key: 'clientCount', direction: 'desc' }); setSearchQuery(''); setMinClientFilter(''); }}
            className={`px-4 py-2 text-sm font-medium rounded-md flex items-center transition-colors ${
              activeTab === 'admins' ? 'bg-[#84bd5e] text-white shadow-sm' : 'text-gray-500 hover:bg-gray-50'
            }`}
          >
            <ShieldCheck className="w-4 h-4 mr-2" />
            3(16) Admins
          </button>
        </div>
      </div>

      <div className="flex-1 bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden flex flex-col">
            <div className="p-4 border-b border-gray-100 bg-white flex flex-col xl:flex-row xl:items-center justify-between gap-4">
                <div className="flex items-center space-x-4">
                    <h3 className="font-bold text-gray-800 text-lg">
                        {activeTab === 'peos' ? 'Professional Employer Organizations' : 
                        activeTab === 'providers' ? '401(k) Document Providers' : '3(16) Fiduciary Administrators'}
                    </h3>
                    <span className="px-2.5 py-0.5 rounded-full bg-gray-100 text-gray-600 text-xs font-medium border border-gray-200">
                        {processedData.length} Records
                    </span>
                </div>
                
                {/* Filter Bar */}
                <div className="flex flex-wrap items-center gap-3">
                    <div className="relative">
                        <Search className="w-4 h-4 text-gray-400 absolute left-3 top-2.5" />
                        <input 
                            type="text" 
                            placeholder="Search name or EIN..." 
                            value={searchQuery}
                            onChange={(e) => setSearchQuery(e.target.value)}
                            className="pl-9 pr-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-1 focus:ring-[#84bd5e] focus:border-[#84bd5e] outline-none w-64 shadow-sm"
                        />
                    </div>

                    <div className="h-8 w-px bg-gray-200 mx-1"></div>

                    <div className="flex items-center space-x-2">
                        <span className="text-xs font-semibold text-gray-500 uppercase">Min Clients:</span>
                        <input 
                            type="number" 
                            placeholder="0" 
                            value={minClientFilter}
                            onChange={(e) => setMinClientFilter(e.target.value)}
                            className="px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-1 focus:ring-[#84bd5e] focus:border-[#84bd5e] outline-none w-24 shadow-sm"
                        />
                    </div>

                    {activeTab === 'peos' && (
                        <>
                            <div className="flex items-center space-x-2">
                                <span className="text-xs font-semibold text-gray-500 uppercase">Min WC Pols:</span>
                                <input 
                                    type="number" 
                                    placeholder="0" 
                                    value={minWCPoliciesFilter}
                                    onChange={(e) => setMinWCPoliciesFilter(e.target.value)}
                                    className="px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-1 focus:ring-[#84bd5e] focus:border-[#84bd5e] outline-none w-24 shadow-sm"
                                />
                            </div>
                            <div className="flex items-center space-x-2">
                                <span className="text-xs font-semibold text-gray-500 uppercase">Trend:</span>
                                <select
                                    value={trendFilter}
                                    onChange={(e) => setTrendFilter(e.target.value)}
                                    className="px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-1 focus:ring-[#84bd5e] focus:border-[#84bd5e] outline-none bg-white shadow-sm"
                                >
                                    <option value="all">All Trends</option>
                                    <option value="up">Growing</option>
                                    <option value="down">Declining</option>
                                    <option value="flat">Flat</option>
                                </select>
                            </div>
                        </>
                    )}

                    {activeTab === 'providers' && (
                        <div className="flex items-center space-x-2">
                            <span className="text-xs font-semibold text-gray-500 uppercase">Min Share %:</span>
                            <input 
                                type="number" 
                                placeholder="0%" 
                                value={minMarketShareFilter}
                                onChange={(e) => setMinMarketShareFilter(e.target.value)}
                                className="px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-1 focus:ring-[#84bd5e] focus:border-[#84bd5e] outline-none w-24 shadow-sm"
                            />
                        </div>
                    )}
                </div>
            </div>
            
            <div className="overflow-auto flex-1">
                <table className="min-w-full divide-y divide-gray-200">
                    <thead className="bg-gray-50 sticky top-0 z-10">
                        <tr>
                            <th 
                                className="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider cursor-pointer hover:bg-gray-100 transition-colors group"
                                onClick={() => handleSort('name')}
                            >
                                <div className="flex items-center">Name <SortIcon columnKey="name" /></div>
                            </th>
                            <th 
                                className="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider cursor-pointer hover:bg-gray-100 transition-colors group"
                                onClick={() => handleSort('clientCount')}
                            >
                                <div className="flex items-center">Client Count <SortIcon columnKey="clientCount" /></div>
                            </th>
                            
                            {activeTab === 'peos' && (
                                <>
                                    <th 
                                        className="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider cursor-pointer hover:bg-gray-100 transition-colors group"
                                        onClick={() => handleSort('wcPolicyCount')}
                                    >
                                        <div className="flex items-center">WC Policies <SortIcon columnKey="wcPolicyCount" /></div>
                                    </th>
                                    <th 
                                        className="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider cursor-pointer hover:bg-gray-100 transition-colors group"
                                        onClick={() => handleSort('avgClientSize')}
                                    >
                                        <div className="flex items-center">Avg Client Size <SortIcon columnKey="avgClientSize" /></div>
                                    </th>
                                    <th className="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Growth Trend</th>
                                </>
                            )}

                            {activeTab === 'providers' && (
                                <>
                                    <th className="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Legal Name</th>
                                    <th 
                                        className="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider cursor-pointer hover:bg-gray-100 transition-colors group"
                                        onClick={() => handleSort('marketShare')}
                                    >
                                        <div className="flex items-center">Market Share <SortIcon columnKey="marketShare" /></div>
                                    </th>
                                </>
                            )}

                            {activeTab === 'admins' && (
                                <th className="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">EIN</th>
                            )}
                        </tr>
                    </thead>
                    <tbody className="bg-white divide-y divide-gray-100">
                        {processedData.map((item: any, idx) => (
                            <tr key={item.id} className={`hover:bg-green-50 transition-colors ${idx % 2 === 0 ? 'bg-white' : 'bg-gray-50/50'}`}>
                                <td className="px-6 py-4 whitespace-nowrap font-medium text-gray-900">{item.name}</td>
                                <td className="px-6 py-4 whitespace-nowrap text-sm text-gray-600 font-mono">
                                    {item.clientCount.toLocaleString()}
                                </td>
                                
                                {activeTab === 'peos' && (
                                    <>
                                        <td className="px-6 py-4 whitespace-nowrap text-sm text-gray-600 font-mono">{item.wcPolicyCount?.toLocaleString()}</td>
                                        <td className="px-6 py-4 whitespace-nowrap text-sm text-gray-600 font-mono">{item.avgClientSize}</td>
                                        <td className="px-6 py-4 whitespace-nowrap text-sm">{getTrendIcon(item.trend)}</td>
                                    </>
                                )}

                                {activeTab === 'providers' && (
                                    <>
                                        <td className="px-6 py-4 whitespace-nowrap text-xs text-gray-500 uppercase tracking-wide">{item.providerName}</td>
                                        <td className="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                                            <div className="flex items-center">
                                                <div className="w-24 bg-gray-200 rounded-full h-2 mr-3">
                                                    <div className="bg-[#84bd5e] h-2 rounded-full" style={{ width: `${Math.min(item.marketShare, 100)}%` }}></div>
                                                </div>
                                                <span className="font-medium">{item.marketShare}%</span>
                                            </div>
                                        </td>
                                    </>
                                )}

                                {activeTab === 'admins' && (
                                    <td className="px-6 py-4 whitespace-nowrap text-sm text-gray-500 font-mono">{item.ein}</td>
                                )}
                            </tr>
                        ))}
                    </tbody>
                </table>
                {processedData.length === 0 && (
                    <div className="p-16 text-center text-gray-500 bg-gray-50">
                        <Filter className="w-12 h-12 mx-auto mb-3 text-gray-300" />
                        <p className="text-lg font-medium text-gray-900">No records match your filters</p>
                        <p className="text-sm mt-1">Try adjusting your search or filter criteria.</p>
                        <button 
                            onClick={() => { setSearchQuery(''); setMinClientFilter(''); setTrendFilter('all'); setMinWCPoliciesFilter(''); setMinMarketShareFilter(''); }}
                            className="mt-4 text-[#84bd5e] hover:text-[#76aa52] font-medium text-sm"
                        >
                            Clear all filters
                        </button>
                    </div>
                )}
            </div>
      </div>
    </div>
  );
};

export default Analytics;
